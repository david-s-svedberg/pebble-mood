<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Needed to open the listening socket (the phone-internal import listener). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Phone mode (fas 5): re-arm the local group reminders after a reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Phase 6: read Pebble health data the Core Devices app writes to HC. -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />

    <application
        android:label="@string/app_name"
        android:theme="@style/Theme.MoodCompanion">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Health Connect shows this when the user taps the app's privacy
                 rationale from the permission screen (required to be granted HC
                 read access). Handled inline by MainActivity. -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Android 14+ variant of the same rationale hook. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- Owns the localhost import listener so sync happens the moment the
             watch app runs, regardless of whether the UI is open. specialUse
             rather than dataSync: Android 15 time-boxes dataSync services
             (~6 h) and killed us with ForegroundServiceDidNotStopInTime; a
             standing watch-sync listener has no natural stop point. -->
        <service
            android:name=".ImportService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Standing localhost listener receiving Pebble watch sync batches" />
        </service>

        <!-- Phone mode (fas 5): fires each group reminder at its scheduled time. -->
        <receiver
            android:name=".phone.ReminderReceiver"
            android:exported="false" />

        <!-- Re-arm the reminders after a device reboot. -->
        <receiver
            android:name=".phone.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
