<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Needed to open the listening socket (the phone-internal import listener). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="@string/app_name"
        android:theme="@style/Theme.MoodCompanion">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Owns the localhost import listener so sync happens the moment the
             watch app runs, regardless of whether the UI is open. specialUse
             rather than dataSync: Android 15 time-boxes dataSync services
             (~6 h) and killed us with ForegroundServiceDidNotStopInTime; a
             standing watch-sync listener has no natural stop point. -->
        <service
            android:name=".ImportService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Standing localhost listener receiving Pebble watch sync batches" />
        </service>
    </application>
</manifest>
